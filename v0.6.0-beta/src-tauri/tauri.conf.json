{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BackupDrive",
  "version": "0.6.0-beta",
  "identifier": "com.backupdrive.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BackupDrive",
        "width": 1040,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "trafficLightPosition": { "x": 18, "y": 20 },
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Desktop backup application",
    "longDescription": "BackupDrive is a fast, lightweight desktop backup tool with a macOS-inspired UI."
  },
  "plugins": {}
}
